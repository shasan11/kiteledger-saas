<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
            <!-- Retained with the dormant assistant add-on candidate. -->
            <exclude>tests/Unit/AiAssistantUiContractTest.php</exclude>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
            <!-- Assistant/chat tests are preserved for future plugin extraction,
                 but are not part of the core report-summary product suite. -->
            <exclude>tests/Feature/AiAssistantApiTest.php</exclude>
            <exclude>tests/Feature/AiToolAgentTest.php</exclude>
            <exclude>tests/Feature/Ai/AiAgentSafetyTest.php</exclude>
            <exclude>tests/Feature/Ai/AiRagRetrieverTest.php</exclude>
            <exclude>tests/Feature/Ai/AiSecurityHardeningTest.php</exclude>
            <exclude>tests/Feature/Ai/AiSemanticSearchTest.php</exclude>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <ini name="memory_limit" value="-1"/>
        <env name="APP_ENV" value="testing"/>
        <env name="SAAS_ALLOW_UNINITIALIZED_TENANT_MODELS" value="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="CENTRAL_DOMAINS" value="central.test"/>
        <env name="SAAS_BASE_DOMAIN" value="test"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
