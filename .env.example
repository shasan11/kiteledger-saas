# These are pre-install defaults only. The web installer (/install) rewrites
# this file with APP_ENV=production and APP_DEBUG=false once setup completes,
# so leave debug ON here — it makes any setup error visible instead of a blank
# 500 page. APP_KEY is intentionally empty so each install generates its own.
APP_NAME=KiteLedger
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com
# Hosts that serve the marketing site + /admin panel (comma separated).
CENTRAL_DOMAINS=example.com,www.example.com
# Suffix appended to each tenant subdomain: acme -> acme.<SAAS_BASE_DOMAIN>.
# For wildcard subdomains in production, point *.<domain> DNS at this app and set
# SAAS_BASE_DOMAIN=yourdomain.com. See docs/WILDCARD_DOMAIN_SETUP.md.
SAAS_BASE_DOMAIN=example.com
CENTRAL_ADMIN_PATH=admin
TRUSTED_PROXY_IPS=

# Full demo data is CLI-only. Normal database seeding always remains
# production-safe; use kiteledger:seed-demo explicitly for sample records.
# Optional CA bundle for Stripe, PayPal, and Razorpay HTTPS requests.
# PAYMENT_GATEWAY_CA_BUNDLE=/absolute/path/to/cacert.pem
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# The web installer (/install) writes these values for you.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kiteledger
DB_USERNAME=root
DB_PASSWORD=

# Tenant databases use the same server credentials by default. The DB user
# must be allowed to CREATE DATABASE in production.
TENANT_DATABASE_PROVISIONING_MODE=pool
TENANT_DB_PREFIX=cpuser_klt_
TENANT_DB_TEMPLATE_CONNECTION=mysql
TENANT_PROVISIONING_QUEUE=provisioning
TENANT_PROVISION_SYNC=false
SUBSCRIPTION_GRACE_PERIOD_DAYS=3
CPANEL_HOST=
CPANEL_PORT=2083
CPANEL_USERNAME=
CPANEL_API_TOKEN=
CPANEL_DATABASE_USER=

CENTRAL_ADMIN_NAME="KiteLedger Super Admin"
CENTRAL_ADMIN_EMAIL=admin@kiteledger.test
CENTRAL_ADMIN_PASSWORD=ChangeMeNow!123
SAAS_BILLING_CURRENCY=USD

SESSION_DRIVER=file
SESSION_CONNECTION=mysql
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
# Keep this null for wildcard tenancy. A dotted domain (e.g. .yourdomain.com)
# shares cookies across ALL tenant subdomains and breaks tenant isolation.
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
DOCUMENT_DISK=local
QUEUE_CONNECTION=sync
DB_QUEUE_CONNECTION=mysql
DB_QUEUE_RETRY_AFTER=330
CACHE_STORE=file
DB_CACHE_CONNECTION=mysql
DB_CACHE_LOCK_CONNECTION=mysql

MAIL_MAILER=smtp
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
# Leave blank so the frontend resolves storage/asset URLs relative to this
# domain — works on root domains, subfolders and CDNs alike. Only set this
# if the API is served from a different origin than the frontend.
VITE_APP_BACKEND_URL=

PRISM_REQUEST_TIMEOUT=120
AI_SSL_VERIFY=true
