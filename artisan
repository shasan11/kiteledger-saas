#!/usr/bin/env php
<?php

use Illuminate\Foundation\Application;
use Symfony\Component\Console\Input\ArgvInput;

define('LARAVEL_START', microtime(true));

// Marketplace archives intentionally omit .env. Keep CLI commands as
// self-bootstrapping as web requests so customers can run Artisan immediately
// after extracting the package without creating configuration files by hand.
if (! is_file(__DIR__.'/.env')) {
    $firstBootReady = require __DIR__.'/bootstrap/first-boot.php';
    $composerDiscovery = ($argv[1] ?? null) === 'package:discover';

    if ($firstBootReady !== true && ! $composerDiscovery) {
        fwrite(STDERR, "Project root is not writable. Make the folder containing artisan writable temporarily so the installer can create .env.\n");
        exit(1);
    }

    if ($firstBootReady !== true) {
        fwrite(STDERR, "Project root is not writable yet; continuing Composer package discovery without creating .env.\n");
    }
}

// Register the Composer autoloader...
require __DIR__.'/vendor/autoload.php';

// Register worktree-specific namespaces so new classes are found
// (needed when vendor is a junction to the main project)
spl_autoload_register(function (string $class): bool {
    $map = [
        'App\\'               => __DIR__ . '/app/',
        'Database\\Seeders\\' => __DIR__ . '/database/seeders/',
        'Database\\Factories\\' => __DIR__ . '/database/factories/',
    ];
    foreach ($map as $prefix => $base) {
        $len = strlen($prefix);
        if (strncmp($prefix, $class, $len) !== 0) {
            continue;
        }
        $file = $base . str_replace('\\', '/', substr($class, $len)) . '.php';
        if (is_file($file)) {
            require $file;
            return true;
        }
    }
    return false;
}, true, true); // prepend so worktree files take priority

// Bootstrap Laravel and handle the command...
/** @var Application $app */
$app = require_once __DIR__.'/bootstrap/app.php';

$status = $app->handleCommand(new ArgvInput);

exit($status);
