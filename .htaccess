<!-- Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Never allow web access to Laravel internals or project metadata.
    RewriteRule "(^|/)\.(?!well-known(?:/|$))" - [F,L,NC]
    RewriteRule "^(?:app|bootstrap|config|database|node_modules|resources|routes|scripts|storage|tests|vendor)(?:/|$)" - [F,L,NC]
    RewriteRule "^(?:artisan|composer\.(?:json|lock)|package(?:-lock)?\.json|phpunit\.xml|vite\.config\.js|webpack\.mix\.js|server\.php)(?:/|$)" - [F,L,NC]

    # Remove /public only when it was explicitly requested by the browser.
    # THE_REQUEST prevents this redirect from firing after the internal rewrite below.
    RewriteCond %{THE_REQUEST} \s/+public(?:[/?\s]|$) [NC]
