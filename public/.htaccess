Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews
    </IfModule>

    RewriteEngine On

    # Reject hidden files if one is ever placed in the public directory while
    # allowing cPanel/AutoSSL validation under .well-known.
    RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L,NC]

    # Preserve the Authorization header for Laravel and API authentication.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Preserve the X-XSRF-Token header for Laravel/Sanctum requests.
    RewriteCond %{HTTP:X-XSRF-Token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Serve existing public files and directories directly. Route everything
    # else through Laravel's front controller.
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
