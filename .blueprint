models:
    AssignedTask: { id: 'uuid primary', task_id: 'uuid foreign:tasks.id', user_id: 'id foreign:users.id', active: 'boolean default:true', is_system_generated: 'boolean default:false', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: Task } }
    Attendance: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id nullable', user_id: 'id foreign:users.id', in_time: datetime, out_time: 'datetime nullable', ip: 'string:60 nullable', comment: 'string:255 nullable', punch_by: 'id foreign:users.id nullable', total_hour: 'decimal:8,2 nullable', in_time_status: 'string:30 nullable', out_time_status: 'string:30 nullable', active: 'boolean default:true', is_system_generated: 'boolean default:false', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: Branch } }
    Award: { id: 'uuid primary', name: 'string:150 unique', description: 'string:255 nullable', image: 'string:255 nullable', active: 'boolean default:true', is_system_generated: 'boolean default:false', user_add_id: 'id foreign:users.id nullable' }
    AwardHistory: { user_id: integer, award_id: string, awarded_date: date, comment: 'string nullable', active: "boolean default:'1'", is_system_generated: "boolean default:'0'", user_add_id: 'integer nullable' }
    Department: { id: 'uuid primary', name: 'string:120', description: 'string:255 nullable', active: 'boolean default:true', is_system_generated: 'boolean default:false', user_add_id: 'id foreign:users.id nullable' }
