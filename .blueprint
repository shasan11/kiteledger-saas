models:
    Branch: { id: 'uuid primary', code: 'string:30 unique', name: 'string:120', phone: 'string:40 nullable', email: 'string:120 nullable', address: 'text nullable', is_head_office: 'boolean default:false', is_transaction_enabled: 'boolean default:true', is_pos_enabled: 'boolean default:true', is_warehouse_enabled: 'boolean default:true', is_ai_enabled: 'boolean default:true', is_billing_location_enabled: 'boolean default:true', abbreviated_tax_enabled: 'boolean default:true', track_location: 'boolean default:true', logo: 'string:255 nullable', favicon: 'string:255 nullable', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable' }
    Currency: { id: 'uuid primary', code: 'string:10 unique', name: 'string:80', symbol: 'string:20 nullable', decimal_places: 'unsignedTinyInteger default:2', is_base: 'boolean default:false', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable' }
    ContactGroup: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', name: 'string:120', parent_id: 'uuid foreign:contact_groups.id nullable', description: 'text nullable', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, ContactGroup:parent', hasMany: 'Contact, ContactGroup:children' } }
    Contact: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', contact_group_id: 'uuid foreign:contact_groups.id nullable', contact_type: 'enum:customer,supplier,lead default:customer', name: 'string:180', code: 'string:50 nullable', address: 'text nullable', pan: 'string:80 nullable', phone: 'string:40 nullable', accept_purchase: 'boolean default:false', email: 'string:120 nullable', credit_term_id: 'uuid foreign:credit_terms.id nullable', credit_limit: 'decimal:16,2 default:0', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, ContactGroup, CreditTerm', hasMany: 'Quotation, Invoice, SalesOrder, ProformaInvoice, CustomerPayment, SalesReturn' } }
    Account: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', name: 'string:120', code: 'string:30 nullable', nature: 'enum:asset,liability,equity,income,expense default:asset', parent_id: 'uuid foreign:accounts.id nullable', is_system_generated: 'boolean default:false', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, Account:parent', hasMany: 'Account:children, ChartOfAccount' } }
    ChartOfAccount: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', account_id: 'uuid foreign:accounts.id', code: 'string:30 unique', name: 'string:150', description: 'text nullable', currency_id: 'uuid foreign:currencies.id nullable', is_system_generated: 'boolean default:false', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, Account, Currency', hasMany: 'JournalVoucherLine, ExpenseLine' } }
    BankAccount: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', type: 'enum:bank,cash default:bank', display_name: 'string:150', code: 'string:30', currency_id: 'uuid foreign:currencies.id', description: 'text nullable', bank_name: 'string:150 nullable', account_name: 'string:150 nullable', account_number: 'string:80 nullable', account_type: 'string:50 nullable', swift_code: 'string:50 nullable', account_id: 'uuid foreign:accounts.id nullable', opening_balance: 'decimal:16,2 default:0', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, Currency, Account', hasMany: 'CashTransfer, ChequeRegister, CustomerPayment, SupplierPayment' } }
    CashTransfer: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', transfer_no: 'string:40 unique nullable', transfer_date: date, from_bank_account_id: 'uuid foreign:bank_accounts.id', reference: 'string:120 nullable', currency_id: 'uuid foreign:currencies.id', total_amount: 'decimal:16,2 default:0', notes: 'text nullable', status: 'enum:draft,posted,cancelled default:draft', user_add_id: 'id foreign:users.id nullable', active: 'boolean default:true', approved: 'boolean default:true', exchange_rate: 'decimal:16,6 default:1', voided: 'boolean default:false', voided_reason: 'text nullable', voided_date: 'date nullable', voided_by_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'BankAccount:from_bank_account, Branch, Currency', hasMany: CashTransferLine } }
    CashTransferLine: { id: 'uuid primary', cash_transfer_id: 'uuid foreign:cash_transfers.id', to_bank_account_id: 'uuid foreign:bank_accounts.id', exchange_rate_to_default: 'decimal:16,6 default:1', amount: 'decimal:16,2 default:0', description: 'string:200 nullable', relationships: { belongsTo: 'BankAccount:to_bank_account, CashTransfer' } }
    ChequeRegister: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', cheque_no: 'string:80', cheque_date: date, issued_date: date, received_date: date, payee_name: 'string:150 nullable', cleared_date: 'date nullable', direction: 'enum:issued,received default:issued', bank_account_id: 'uuid foreign:bank_accounts.id', account_id: 'uuid foreign:accounts.id nullable', amount: 'decimal:16,2 default:0', status: 'enum:pending,cleared,bounced,cancelled default:pending', notes: 'text nullable', active: 'boolean default:true', approved: 'boolean default:true', voided: 'boolean default:false', voided_reason: 'text nullable', voided_date: 'date nullable', voided_by_id: 'id foreign:users.id nullable', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, BankAccount, Account' } }
    JournalVoucher: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', voucher_no: 'string:40 unique', voucher_date: date, currency_id: 'uuid foreign:currencies.id nullable', exchange_rate: 'decimal:16,6 default:1', reference: 'string:120 nullable', narration: 'text nullable', status: 'enum:draft,posted,cancelled default:draft', user_add_id: 'id foreign:users.id nullable', active: 'boolean default:true', approved: 'boolean default:true', voided: 'boolean default:false', voided_reason: 'text nullable', voided_date: 'date nullable', voided_by_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, Currency', hasMany: JournalVoucherLine } }
    JournalVoucherLine: { id: 'uuid primary', journal_voucher_id: 'uuid foreign:journal_vouchers.id', chart_of_account_id: 'uuid foreign:chart_of_accounts.id', description: 'string:200 nullable', debit: 'decimal:16,2 default:0', credit: 'decimal:16,2 default:0', relationships: { belongsTo: 'JournalVoucher, ChartOfAccount' } }
    TaxClass: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', name: 'string:120', code: 'string:30 unique', description: 'text nullable', active: 'boolean default:true', is_system_generated: 'boolean default:false', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: Branch, hasMany: TaxRate } }
    TaxRate: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', tax_class_id: 'uuid foreign:tax_classes.id', name: 'string:120', rate_percent: 'decimal:8,4 default:0', inclusive: 'boolean default:false', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, TaxClass' } }
    CreditTerm: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', name: 'string:120', days: 'unsignedSmallInteger default:0', description: 'text nullable', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: Branch, hasMany: Contact } }
    ProductCategory: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', name: 'string:120', parent_id: 'uuid foreign:product_categories.id nullable', description: 'text nullable', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, ProductCategory:parent', hasMany: 'ProductCategory:children, Product' } }
    Variant: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', name: 'string:80', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: Branch, hasMany: VariantLine } }
    VariantLine: { id: 'uuid primary', variant_id: 'uuid foreign:variants.id', value: 'string:80', sort_order: 'unsignedSmallInteger default:0', active: 'boolean default:true', relationships: { belongsTo: Variant, hasMany: ProductVariantItem } }
    ProductUnit: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', name: 'string:50', short_name: 'string:20 nullable', precision: 'unsignedTinyInteger default:0', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: Branch, hasMany: 'Product, ProductVariant' } }
    Product: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', product_category_id: 'uuid foreign:product_categories.id nullable', name: 'string:180', code: 'string:60 nullable', barcode: 'string:80 nullable', description: 'text nullable', product_unit_id: 'uuid foreign:product_units.id nullable', tax_class_id: 'uuid foreign:tax_classes.id nullable', track_inventory: 'boolean default:true', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, ProductCategory, ProductUnit, TaxClass', hasMany: ProductVariant } }
    ProductVariant: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', product_id: 'uuid foreign:products.id', name: 'string:180 nullable', sku: 'string:80 nullable', product_unit_id: 'uuid foreign:product_units.id nullable', purchase_price: 'decimal:16,2 default:0', selling_price: 'decimal:16,2 default:0', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, Product, ProductUnit', hasMany: 'ProductVariantItem, QuotationLine, InvoiceLine, SalesOrderLine, ProformaInvoiceLine, SalesReturnLine, PurchaseOrderLine, PurchaseBillLine, DebitNoteLine, InventoryAdjustmentLine, WarehouseTransferLine' } }
    ProductVariantItem: { id: 'uuid primary', product_variant_id: 'uuid foreign:product_variants.id', variant_line_id: 'uuid foreign:variant_lines.id', relationships: { belongsTo: 'ProductVariant, VariantLine' } }
    Warehouse: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', code: 'string:30 nullable', name: 'string:150', address: 'text nullable', active: 'boolean default:true', user_add_id: 'id foreign:users.id nullable', relationships: { belongsTo: Branch, hasMany: 'WarehouseTransfer, InventoryAdjustment, Quotation, Invoice, SalesOrder, ProformaInvoice, SalesReturn, PurchaseOrder, PurchaseBill' } }
    WarehouseTransfer: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', transfer_no: 'string:40 unique', transfer_date: date, from_warehouse_id: 'uuid foreign:warehouses.id', to_warehouse_id: 'uuid foreign:warehouses.id', notes: 'text nullable', status: 'enum:draft,posted,cancelled default:draft', user_add_id: 'id foreign:users.id nullable', active: 'boolean default:true', approved: 'boolean default:true', voided: 'boolean default:false', voided_reason: 'text nullable', voided_date: 'date nullable', voided_by_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, Warehouse:from_warehouse, Warehouse:to_warehouse', hasMany: WarehouseTransferLine } }
    WarehouseTransferLine: { id: 'uuid primary', warehouse_transfer_id: 'uuid foreign:warehouse_transfers.id', product_variant_id: 'uuid foreign:product_variants.id', qty: 'decimal:16,4 default:0', remarks: 'string:200 nullable', relationships: { belongsTo: 'WarehouseTransfer, ProductVariant' } }
    InventoryAdjustment: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', adjustment_no: 'string:40 unique', adjustment_date: date, warehouse_id: 'uuid foreign:warehouses.id', reason: 'string:150 nullable', notes: 'text nullable', status: 'enum:draft,posted,cancelled default:draft', user_add_id: 'id foreign:users.id nullable', active: 'boolean default:true', approved: 'boolean default:true', voided: 'boolean default:false', voided_reason: 'text nullable', voided_date: 'date nullable', voided_by_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, Warehouse', hasMany: InventoryAdjustmentLine } }
    InventoryAdjustmentLine: { id: 'uuid primary', inventory_adjustment_id: 'uuid foreign:inventory_adjustments.id', product_variant_id: 'uuid foreign:product_variants.id', adjustment_type: 'enum:increase,decrease default:increase', qty: 'decimal:16,4 default:0', unit_cost: 'decimal:16,2 default:0', remarks: 'string:200 nullable', active: 'boolean default:true', approved: 'boolean default:true', voided: 'boolean default:false', voided_reason: 'text nullable', voided_date: 'date nullable', voided_by_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'InventoryAdjustment, ProductVariant' } }
    Quotation: { id: 'uuid primary', branch_id: 'uuid foreign:branches.id', contact_id: 'uuid foreign:contacts.id', quotation_no: 'string:40 unique nullable', quotation_date: date, expiry_date: 'date nullable', credit_term_id: 'uuid foreign:credit_terms.id nullable', currency_id: 'uuid foreign:currencies.id nullable', exchange_rate: 'decimal:16,6 default:1', notes: 'text nullable', status: 'enum:draft,sent,accepted,rejected,expired,cancelled default:draft', user_add_id: 'id foreign:users.id nullable', active: 'boolean default:true', approved: 'boolean default:true', voided: 'boolean default:false', voided_reason: 'text nullable', voided_date: 'date nullable', voided_by_id: 'id foreign:users.id nullable', relationships: { belongsTo: 'Branch, Contact, CreditTerm, Currency', hasMany: QuotationLine } }
    QuotationLine: { id: 'uuid primary', quotation_id: 'uuid foreign:quotations.id', product_variant_id: 'uuid foreign:product_variants.id nullable', product_name: 'string:180 nullable', description: 'string:200 nullable', qty: 'decimal:16,4 default:0', unit_price: 'decimal:16,2 default:0', discount_percent: 'decimal:8,4 default:0', tax_rate_id: 'uuid foreign:tax_rates.id nullable', tax_amount: 'decimal:16,2 default:0', relationships: { belongsTo: 'Quotation, ProductVariant, TaxRate' } }
